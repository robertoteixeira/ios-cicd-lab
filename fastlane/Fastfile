default_platform(:ios)

IOS_PROJECT = "CICDLabApp/CICDLabApp.xcodeproj"
IOS_SCHEME = "CICDLabApp"
APP_IDENTIFIER = "com.roberto.CICDLabApp"
SIMULATOR_DESTINATION = "generic/platform=iOS Simulator"
TEST_DEVICE = "iPhone 16"
ARCHIVE_DESTINATION = "generic/platform=iOS"
BUILD_OUTPUT_DIRECTORY = "build"
ARCHIVE_PATH = "#{BUILD_OUTPUT_DIRECTORY}/CICDLabApp.xcarchive"
IPA_OUTPUT_DIRECTORY = "#{BUILD_OUTPUT_DIRECTORY}/ipa"
IPA_OUTPUT_NAME = "CICDLabApp.ipa"
EXPORT_METHOD = "app-store"

platform :ios do
  desc "Prepare and build app in CI"
  lane :ci_build do
    set_ci_build_number
    build
  end

  desc "Run tests in CI"
  lane :ci_test do
    test
  end

  desc "Create an archive in CI"
  lane :ci_archive do
    set_ci_build_number
    archive
  end

  desc "Create a signed IPA in CI"
  lane :ci_package do
    set_ci_build_number
    archive
    export_ipa
  end

  desc "Build the iOS app for simulator"
  lane :build do
    xcodebuild(
      project: IOS_PROJECT,
      scheme: IOS_SCHEME,
      destination: SIMULATOR_DESTINATION
    )
  end

  desc "Increment the iOS build number"
  lane :increment_build do
    increment_build_number(
      xcodeproj: IOS_PROJECT
    )
  end

  desc "Set build number from CI"
  lane :set_ci_build_number do
    build_number = ENV["CI_BUILD_NUMBER"] || ENV["GITHUB_RUN_NUMBER"]

    UI.user_error!("CI_BUILD_NUMBER or GITHUB_RUN_NUMBER is required") unless build_number

    increment_build_number(
      build_number: build_number,
      xcodeproj: IOS_PROJECT,
      skip_info_plist: true
    )
  end

  desc "Run iOS tests"
  lane :test do
    scan(
      project: IOS_PROJECT,
      scheme: IOS_SCHEME,
      device: TEST_DEVICE
    )
  end

  desc "Print the current app version and build number"
  lane :version_info do
    version = get_version_number(
      xcodeproj: IOS_PROJECT,
      target: IOS_SCHEME
    )

    build_number = get_build_number(
      xcodeproj: IOS_PROJECT
    )

    UI.message("Marketing version: #{version}")
    UI.message("Build number: #{build_number}")
  end

  desc "Set the marketing version"
  lane :set_version do |options|
    version = options[:version]

    UI.user_error!("Pass a version, for example: fastlane ios set_version version:1.1.0") unless version

    increment_version_number(
      version_number: version,
      xcodeproj: IOS_PROJECT
    )
  end  

  desc "Archive the iOS app"
  lane :archive do
    gym(
      project: IOS_PROJECT,
      scheme: IOS_SCHEME,
      configuration: "Release",
      destination: ARCHIVE_DESTINATION,
      archive_path: ARCHIVE_PATH,
      skip_package_ipa: true,
      clean: true
    )
  end
  
  desc "Export an IPA from the app archive"
  lane :export_ipa do
    profile_name = ENV["APP_STORE_PROVISIONING_PROFILE"]

    UI.user_error!("APP_STORE_PROVISIONING_PROFILE is required") unless profile_name

    gym(
      project: IOS_PROJECT,
      scheme: IOS_SCHEME,
      configuration: "Release",
      archive_path: ARCHIVE_PATH,
      output_directory: IPA_OUTPUT_DIRECTORY,
      output_name: IPA_OUTPUT_NAME,
      export_method: EXPORT_METHOD,
      skip_build_archive: true,
      export_options: {
        method: EXPORT_METHOD,
        provisioningProfiles: {
          APP_IDENTIFIER => profile_name
        }
      }
    )
  end
  
end
